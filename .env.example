DEBUG=1
DJANGO_SECRET_KEY=replace-this-key
ALLOWED_HOSTS=*

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-nano
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_MAX_OUTPUT_TOKENS=96
VOICE_REPLY_MAX_CHARS=180
STT_PROVIDER=sarvam
TTS_PROVIDER=sarvam
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_API_BASE=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_STT_WEBHOOK_ENABLED=0
SARVAM_STT_WEBHOOK_URL=
SARVAM_STT_WEBHOOK_SECRET=
SARVAM_STT_WEBHOOK_WAIT_SEC=12
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=pooja
SARVAM_TTS_PACE=1.0
SARVAM_TTS_TEMPERATURE=0.6
SARVAM_TTS_AUDIO_CODEC=mp3
SARVAM_WEBHOOK_ENABLED=0
SARVAM_WEBHOOK_URL=
SARVAM_WEBHOOK_SECRET=
SARVAM_WEBHOOK_WAIT_SEC=12

LIPSYNC_ENGINE=musetalk
NON_LIPSYNC_FORCE_CPU=1
LIPSYNC_GPU_ID=0

SADTALKER_PATH=
SADTALKER_PYTHON=.venv/Scripts/python.exe
SADTALKER_AUTO_SETUP=1
SADTALKER_GITHUB_URL=https://github.com/OpenTalker/SadTalker.git
SADTALKER_DIR=.models/SadTalker
SADTALKER_EXTRA_ARGS=--still --preprocess crop --size 256
MUSE_TALK_DIR=.models/MuseTalk
MUSE_TALK_PYTHON=.venv_musetalk/Scripts/python.exe
MUSE_TALK_GPU_ID=0
MUSE_TALK_VERSION=v15
MUSE_TALK_BATCH_SIZE=8
MUSE_TALK_FPS=25
MUSE_TALK_USE_FLOAT16=1
MUSE_TALK_EXTRA_MARGIN=10
MUSE_TALK_USE_SAVED_COORD=1
MUSE_TALK_SAVE_COORD=1
MUSE_TALK_FFMPEG_PATH=
MUSE_TALK_PERSISTENT_WORKER=1
MUSE_TALK_WORKER_TIMEOUT_SEC=240
MUSE_TALK_FAST_BATCH_SIZE=24
MUSE_TALK_FAST_FPS=15
MUSE_TALK_USE_FAST_PROFILE=1
MUSE_TALK_AUDIO_PADDING_LEFT=1
MUSE_TALK_AUDIO_PADDING_RIGHT=1

DEFAULT_AVATAR_IMAGE=static/core/default-avatar-woman.png
DEFAULT_AVATAR_VIDEO=static/core/Realistic_Avatar_Video_Generation.mp4

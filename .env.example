DEBUG=1
DJANGO_SECRET_KEY=replace-this-key
ALLOWED_HOSTS=*

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_OUTPUT_TOKENS=180
VOICE_REPLY_MAX_CHARS=2000
CHAT_REPLY_MAX_CHARS=900
TTS_MAX_SENTENCES=50

STT_PROVIDER=sarvam
TTS_PROVIDER=sarvam
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_API_BASE=https://api.sarvam.ai
SARVAM_WS_BASE=wss://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=rahul
SARVAM_TTS_SPEAKER_ENGLISH=rahul
SARVAM_TTS_SPEAKER_NORTH=priya
SARVAM_TTS_SPEAKER_SOUTH=pooja
SARVAM_TTS_PACE=1.05
SARVAM_TTS_TEMPERATURE=0.6
SARVAM_TTS_AUDIO_CODEC=mp3
SARVAM_REQUEST_TIMEOUT_SEC=45
SARVAM_MAX_RETRIES=2
SARVAM_RETRY_BACKOFF_SEC=0.8

LIPSYNC_ENGINE=musetalk
MUSE_TALK_PERSISTENT_WORKER=1
MUSE_TALK_MULTI_AVATAR_POOL=1
AUTO_MODEL_WARMUP=1
MUSE_TALK_PERSISTENT_FALLBACK_ONESHOT=1
MUSE_TALK_KEEP_AVATAR_CACHE=1
MUSE_TALK_REBUILD_CACHE_ON_FAIL=0
MUSE_TALK_WORKER_TIMEOUT_SEC=90
MUSE_TALK_USE_FAST_PROFILE=1
MUSE_TALK_FAST_FPS=14
MUSE_TALK_FAST_BATCH_SIZE=11
MUSE_TALK_AUDIO_PADDING_LEFT=1
MUSE_TALK_AUDIO_PADDING_RIGHT=1

AVATAR_VIDEO_ENGLISH=static/core/Avatar_Suit_Creation_and_Video.mp4
AVATAR_VIDEO_NORTH=static/core/Realistic_Avatar_Video_Generation.mp4
AVATAR_VIDEO_SOUTH=static/core/Telugu_Avatar_Assistant_Saree_Video.mp4
AVATAR_LIPSYNC_VIDEO_ENGLISH=static/core/Avatar_Suit_Creation_and_Video_musetalk_opt.mp4
AVATAR_LIPSYNC_VIDEO_NORTH=static/core/Realistic_Avatar_Video_Generation_musetalk_opt.mp4
